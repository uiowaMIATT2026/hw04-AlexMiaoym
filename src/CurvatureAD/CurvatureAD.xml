<?xml version="1.0" encoding="utf-8"?>
<executable>
    <category>MIATT.HW04.yuamiao</category>
        <title>Curvature Anisotropic Diffusion</title>
        <description>
        Curvature Anisotropic Diffusion filter.
    </description>
    <version>1.0</version>
    <documentation-url></documentation-url>
    <license></license>
    <contributor>Yuanmin Miao</contributor>

    <parameters>
        <label>CurvatureAD Parameters</label>
        <description>
        Parameters for Curvature Anisotropic Diffusion filter
        </description>

        <double>
            <name>conductance</name>
            <longflag>conductance</longflag>
            <description>Conductance for Curvature Anisotropic Diffusion filter </description>
            <label>Conductance</label>
            <default>2.0</default>
        </double>
        <double>
            <name>timeStep</name>
            <longflag>timeStep</longflag>
            <description>Time step for Curvature Anisotropic Diffusion filter </description>
            <label>Time Step</label>
            <default>0.1</default>
        </double>
        <integer>
            <name>iterations</name>
            <longflag>iterations</longflag>
            <description>Number of iterations for Curvature Anisotropic Diffusion filter </description>
            <label>Iterations</label>
            <default>5</default>
        </integer>
    </parameters>

    <parameters>
        <label>IO</label>
        <description>Input/output parameters</description>
        <image>
            <name>input</name>
            <longflag>inputVolume</longflag>
            <label>Input Volume</label>
            <channel>input</channel>
            <description>Input volume to be filtered</description>
        </image>
        <image>
            <name>output</name>
            <longflag>outputVolume</longflag>
            <label>Output Volume</label>
            <channel>output</channel>
            <description>Output filtered</description>
        </image>
    </parameters>

    <!-- Other parameters here -->
</executable>
