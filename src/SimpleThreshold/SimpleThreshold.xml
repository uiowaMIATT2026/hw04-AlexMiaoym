<?xml version="1.0" encoding="utf-8"?>
<executable>
    <category>MIATT.HW04.yuamiao</category>
    <title>Simple Threshold</title>
    <description>
        This program is used to threshold an image.
    </description>
    <version>1.0</version>
    <documentation-url></documentation-url>
    <license></license>
    <contributor>Yuanmin Miao</contributor>

    <parameters>
        <label>Threshold Parameters</label>
        <description>
        Parameters for thresholding
        </description>

        <integer>
            <name>lowThreshold</name>
            <longflag>lowThreshold</longflag>
            <description>Lower threshold for thresholding </description>
            <label>Low Threshold</label>
            <default>50</default>
        </integer>

        <integer>
            <name>highThreshold</name>
            <longflag>highThreshold</longflag>
            <description>Upper threshold for thresholding </description>
            <label>High Threshold</label>
            <default>100</default>
        </integer>

        <integer>
            <name>outsideValue</name>
            <longflag>outsideValue</longflag>
            <description>Value for outside pixels </description>
            <label>Outside Value</label>
            <default>150</default>
        </integer>

        <integer>
            <name>insideValue</name>
            <longflag>insideValue</longflag>
            <description>Value for inside pixels </description>
            <label>Inside Value</label>
            <default>200</default>
        </integer>

    </parameters>

    <parameters>
        <label>IO</label>
        <description>Input/output parameters</description>
        <image>
            <name>input</name>
            <longflag>inputVolume</longflag>
            <label>Input Volume</label>
            <channel>input</channel>
            <description>Input volume to be filtered</description>
        </image>
        <image>
            <name>output</name>
            <longflag>outputVolume</longflag>
            <label>Output Volume</label>
            <channel>output</channel>
            <description>Output filtered</description>
        </image>
    </parameters>

    <!-- Other parameters here -->
</executable>
