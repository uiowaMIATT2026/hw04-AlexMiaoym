<?xml version="1.0" encoding="utf-8"?>
<executable>
    <category>MIATT.HW04.yuamiao</category>
        <title>Simple Threshold</title>
        <description>
        3D Gaussian low-pass filter.
    </description>
    <version>1.0</version>
    <documentation-url></documentation-url>
    <license></license>
    <contributor>Yuanmin Miao</contributor>

    <parameters>
        <label>Gaussian LPF Parameters</label>
        <description>
        Parameters for Gaussian LPF
        </description>

        <double>
            <name>sigma</name>
            <longflag>sigma</longflag>
            <description>Sigma for Gaussian LPF </description>
            <label>Sigma</label>
            <default>2.5</default>
            <constraints>
            <minimum>0.0</minimum>
            <maximum>20.0</maximum>
            <step>0.1</step>
            </constraints>
        </double>

    </parameters>

    <parameters>
        <label>IO</label>
        <description>Input/output parameters</description>
        <image>
            <name>input</name>
            <longflag>inputVolume</longflag>
            <label>Input Volume</label>
            <channel>input</channel>
            <description>Input volume to be filtered</description>
        </image>
        <image>
            <name>output</name>
            <longflag>outputVolume</longflag>
            <label>Output Volume</label>
            <channel>output</channel>
            <description>Output filtered</description>
        </image>
    </parameters>

    <!-- Other parameters here -->
</executable>
